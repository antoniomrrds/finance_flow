root = true

[*.cs]
indent_size = 4
indent_style = space
tab_width = 4

charset = utf-8
end_of_line = lf
insert_final_newline = true

# var preferences
csharp_style_var_elsewhere = false:error
csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = true:error

[**/Migrations/**.cs]
dotnet_diagnostic.CA1707.severity = none
[**tests/**.cs]
dotnet_diagnostic.CA1707.severity = none